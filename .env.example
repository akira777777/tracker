# Local development SQLite database.
DATABASE_URL="file:./dev.db"

# Docker/production example for the mounted container volume:
# DATABASE_URL="file:/app/data/prod.db"

ADMIN_PASSWORD="change-this-password"
AUTH_SECRET="replace-with-a-long-random-string"
IP_HASH_SALT="replace-with-a-different-long-random-string"
ANALYTICS_RETENTION_DAYS="30"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal log ingestion. Use a long random token in production.
INTERNAL_LOG_TOKEN="replace-with-a-long-random-log-token"
# Optional remote/private-network collector; when omitted, logs stay in-process.
# INTERNAL_LOG_ENDPOINT="http://tracker:3000/api/internal/logs"
